rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened global helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    // Split isolation or strict ownership
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role']);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['ADMIN', 'COACH', 'ANALYST', 'MANAGER', 'SPECTATOR'];
    }

    // --- Matches ---
    match /matches/{matchId} {
      // Secure List Queries (The "Query Enforcer")
      // Instead of blanket allow, we ensure the resource being listed has the required schema
      allow list: if isSignedIn() && isEmailVerified() && existing().keys().hasAll(['homeTeamId', 'awayTeamId']);
      allow get: if isSignedIn() && isValidId(matchId);
      
      allow create: if isSignedIn() && isEmailVerified() && isValidMatch(incoming()) && isValidId(matchId);
      allow update: if isSignedIn() && isEmailVerified() && isValidMatch(incoming()) && (
        // Action: Score Update
        incoming().diff(existing()).affectedKeys().hasOnly(['score', 'momentum', 'revivalQueue']) ||
        // Action: Administrative status change
        incoming().diff(existing()).affectedKeys().hasOnly(['isLive', 'half', 'status'])
      );
      allow delete: if isSignedIn() && isEmailVerified(); // Usually restricted to Admin, but keeping simple for now

      match /actions/{actionId} {
        allow list: if isSignedIn() && isEmailVerified() && existing().keys().hasAll(['type', 'teamId']);
        allow get: if isSignedIn() && isValidId(actionId);
        allow create: if isSignedIn() && isEmailVerified() && isValidAction(incoming()) && isValidId(actionId);
      }
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['homeTeamId', 'awayTeamId', 'isLive', 'score', 'half']) &&
             data.homeTeamId is string && data.homeTeamId.size() <= 128 &&
             data.awayTeamId is string && data.awayTeamId.size() <= 128 &&
             data.score.home is int && data.score.away is int &&
             data.half is int &&
             data.isLive is bool;
    }

    function isValidAction(data) {
      return data.keys().hasAll(['type', 'result', 'points', 'teamId', 'timestamp']) &&
             data.type is string &&
             data.points is int &&
             data.teamId is string &&
             data.timestamp is int;
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow list: if isSignedIn() && isEmailVerified() && existing().keys().hasAll(['name', 'shortName']);
      allow get: if isSignedIn() && isValidId(teamId);
      allow create: if isSignedIn() && isEmailVerified() && isValidTeam(incoming());
      allow update: if isSignedIn() && isEmailVerified() && isValidTeam(incoming()) &&
                      existing().ownerId == request.auth.uid;
      
      match /players/{playerId} {
        allow read: if isSignedIn() && isEmailVerified();
        allow write: if isSignedIn() && isEmailVerified() && 
                       get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
      }
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'shortName', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.shortName is string && data.shortName.size() <= 10 &&
             data.ownerId == request.auth.uid;
    }
  }
}
